{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "240bb9954c7f7d761207e9ea9d470f6aab31852a",
  "force-tag-creation": true,
  "release-type": "rust",
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "ajax-cli",
      "components": ["ajax-cli"]
    }
  ],
  "packages": {
    "crates/ajax-cli": {
      "component": "ajax-cli",
      "package-name": "ajax-cli",
      "release-type": "rust",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/ajax-core": {
      "component": "ajax-cli",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-supervisor": {
      "component": "ajax-cli",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-tui": {
      "component": "ajax-cli",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-web": {
      "component": "ajax-cli",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    }
  }
}
