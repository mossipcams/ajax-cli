{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "plugins": [
    "cargo-workspace",
    {
      "type": "linked-versions",
      "groupName": "ajax-cli",
      "components": [
        "ajax-cli",
        "ajax-core",
        "ajax-supervisor",
        "ajax-tui",
        "ajax-web"
      ]
    }
  ],
  "packages": {
    "crates/ajax-cli": {
      "component": "ajax-cli",
      "package-name": "ajax-cli",
      "release-type": "rust",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/ajax-core": {
      "component": "ajax-core",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-supervisor": {
      "component": "ajax-supervisor",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-tui": {
      "component": "ajax-tui",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    },
    "crates/ajax-web": {
      "component": "ajax-web",
      "release-type": "rust",
      "skip-changelog": true,
      "skip-github-release": true
    }
  }
}
