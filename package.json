{
  "name": "ajax-cli",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npm run verify",
    "verify": "cargo fmt --check && cargo check --all-targets --all-features && cargo clippy --all-targets --all-features -- -D warnings && cargo nextest run --all-features --test-threads=1 && cargo test --doc && npm run web:check && npm run web:test -- --run",
    "web:check": "tsc -p crates/ajax-web/web/tsconfig.check.json --noEmit && node scripts/svelte-check-legacy-ts.cjs --tsconfig crates/ajax-web/web/tsconfig.check.json",
    "web:test": "vitest --config crates/ajax-web/web/vite.config.mts",
    "web:build": "vite build --config crates/ajax-web/web/vite.config.mts",
    "web:build:check": "node scripts/web-build-check.mjs",
    "web:dev": "vite --config crates/ajax-web/web/vite.config.mts",
    "web:smoke": "playwright test --config crates/ajax-web/web/playwright.config.mts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/svelte": "^5.2.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.7.2",
    "tailwindcss": "4.3.3",
    "typescript": "^7.0.2",
    "typescript-5": "npm:typescript@^5.9.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
