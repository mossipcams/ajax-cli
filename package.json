{
  "name": "ajax-cli",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npm run verify",
    "verify": "cargo fmt --check && cargo check --all-targets --all-features && cargo clippy --all-targets --all-features -- -D warnings && cargo nextest run --all-features --test-threads=1 && cargo test --doc && npm run lint:duplication && npm run web:check && npm run web:test -- --run",
    "lint:duplication": "jscpd --config .jscpd.json",
    "verify:probity": "node scripts/verify-probity.mjs",
    "verify:web-contract-gate": "node scripts/verify-web-contract-gate.mjs",
    "dev:web": "./scripts/dev-web-restart.sh",
    "web:check": "svelte-check --tsconfig crates/ajax-web/web/tsconfig.json",
    "web:test": "vitest --config crates/ajax-web/web/vite.config.mts",
    "web:build": "vite build --config crates/ajax-web/web/vite.config.mts",
    "web:build:check": "node scripts/web-build-check.mjs",
    "web:dist:check": "node scripts/web-dist-check.mjs",
    "web:dev": "vite --config crates/ajax-web/web/vite.config.mts",
    "web:smoke": "playwright test --config crates/ajax-web/web/playwright.config.mts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nizos/probity": "^1.5.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "husky": "^9.1.7",
    "jscpd": "^4.2.3",
    "jsdom": "^25.0.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
